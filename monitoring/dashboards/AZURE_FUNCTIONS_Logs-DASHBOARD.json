            "targets": [
                {
                    "datasource": {
                        "type": "grafana-azure-monitor-datasource",
                        "uid": "${DS_AZURE_MONITOR}"
                    },
                    "queryType": "Azure Log Analytics",
                    "refId": "A",
                    "azureLogAnalytics": {
                        "resources": [
                            "${app_insights_id}"
                        ],
                        "query": "traces\n| where $__timeFilter(timestamp)\n| where '$search' == '' or message contains '$search'\n| extend level = case(\n    severityLevel == 0, 'trace',\n    severityLevel == 1, 'info',\n    severityLevel == 2, 'warning',\n    severityLevel == 3, 'error',\n    severityLevel == 4, 'critical',\n    'info'\n)\n| project timestamp, message, level, operation_Name\n| order by timestamp asc",
                        "resultFormat": "logs",
                        "dashboardTime": true
                    }
                }
            ],
            "title": "Logs — ${app_insights_id:text}",
            "type": "logs"
        }
    ],
    "refresh": "3s",
